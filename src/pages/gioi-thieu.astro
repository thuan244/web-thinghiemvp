---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const base = import.meta.env.BASE_URL;

const values = [
  {
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>',
    title: "Trung Thực",
    desc: "Số liệu thí nghiệm luôn phản ánh đúng thực tế, không vì lợi ích nào mà thay đổi kết quả.",
  },
  {
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
    title: "Chuyên Nghiệp",
    desc: "Quy trình thí nghiệm được thực hiện theo đúng tiêu chuẩn TCVN và quy chuẩn hiện hành.",
  },
  {
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>',
    title: "Tận Tâm",
    desc: "Luôn đặt lợi ích của đối tác lên hàng đầu, hỗ trợ tư vấn miễn phí và giải quyết vướng mắc kịp thời.",
  },
  {
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>',
    title: "Phát Triển",
    desc: "Không ngừng đầu tư nâng cấp thiết bị, đào tạo nhân sự để đáp ứng yêu cầu ngày càng cao.",
  },
];
---

<BaseLayout title="Giới Thiệu | VP Construction & Testing - LAS-XD 53.003">
  <PageHero
    title="Giới Thiệu Công Ty"
    description="Hơn 2 năm kinh nghiệm trong lĩnh vực thí nghiệm vật liệu xây dựng và kiểm định công trình được khách hàng đánh giá cao."
    breadcrumb="Giới Thiệu"
  />

  <div class="max-w-7xl mx-auto px-4 md:px-10 lg:px-20">
    <!-- Company Overview -->
    <section class="py-20">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6">
          <div class="flex items-center gap-2">
            <div class="w-10 h-[2px] bg-accent"></div>
            <span
              class="text-accent font-heading font-bold uppercase tracking-widest text-sm"
              >Tổng Quan</span
            >
          </div>
          <h2
            class="text-3xl md:text-4xl font-heading font-extrabold text-text-primary leading-tight"
          >
            CÔNG TY TNHH XÂY DỰNG VÀ THÍ NGHIỆM KIỂM ĐỊNH VP
          </h2>
          <p class="text-text-secondary leading-relaxed">
            Được thành lập năm 2024, Công ty TNHH Xây Dựng Và Thí Nghiệm Kiểm
            Định VP đã nhanh chóng khẳng định vị thế là đơn vị uy tín hàng đầu
            tại Miền Bắc và trên toàn quốc trong lĩnh vực thí nghiệm vật liệu
            xây dựng và kiểm định chất lượng công trình.
          </p>
          <p class="text-text-secondary leading-relaxed">
            Với phòng thí nghiệm đạt chuẩn <span class="font-bold text-primary"
              >LAS-XD 53.003</span
            > do Bộ Xây Dựng cấp, chúng tôi có năng lực thực hiện 128 chỉ tiêu thí
            nghiệm trên các loại vật liệu: bê tông, xi măng, cốt thép, đất, đá, cát,
            nhựa đường và nhiều loại vật liệu khác.
          </p>
          <div class="grid grid-cols-2 gap-4 pt-4">
            <div class="bg-accent/5 p-4 rounded-xl text-center">
              <p class="text-2xl font-heading font-extrabold text-primary">
                100+
              </p>
              <p class="text-xs text-text-secondary font-medium mt-1">
                Thiết bị hiện đại
              </p>
            </div>
            <div class="bg-accent/5 p-4 rounded-xl text-center">
              <p class="text-2xl font-heading font-extrabold text-primary">
                128
              </p>
              <p class="text-xs text-text-secondary font-medium mt-1">
                Chỉ tiêu thí nghiệm
              </p>
            </div>
          </div>
        </div>

        <!-- Image area -->
        <div class="relative">
          <div
            class="aspect-[4/3] rounded-2xl overflow-hidden shadow-hero bg-gradient-to-br from-primary/10 to-accent/10 flex items-center justify-center"
          >
            <img
              src={`${base}images/logo-400.png`}
              alt="VP Construction Logo"
              class="w-48 h-48 object-contain"
              width="192"
              height="192"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Vision & Mission -->
    <section class="py-20 border-t border-border">
      <div class="grid md:grid-cols-2 gap-12">
        <div class="bg-primary p-10 rounded-2xl text-white">
          <div
            class="w-14 h-14 bg-white/10 rounded-xl flex items-center justify-center mb-6"
          >
            <svg
              class="w-7 h-7"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
              ></path></svg
            >
          </div>
          <h3 class="text-2xl font-heading font-extrabold mb-4">Tầm Nhìn</h3>
          <p class="text-white/80 leading-relaxed">
            Trở thành đơn vị thí nghiệm và kiểm định xây dựng hàng đầu khu vực
            phía Bắc, được công nhận về chất lượng dịch vụ và uy tín trong
            ngành. Hướng tới tiêu chuẩn quốc tế ISO/IEC 17025.
          </p>
        </div>
        <div class="bg-white p-10 rounded-2xl border border-border shadow-card">
          <div
            class="w-14 h-14 bg-accent/10 rounded-xl flex items-center justify-center mb-6 text-accent"
          >
            <svg
              class="w-7 h-7"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"></path></svg
            >
          </div>
          <h3
            class="text-2xl font-heading font-extrabold text-text-primary mb-4"
          >
            Sứ Mệnh
          </h3>
          <p class="text-text-secondary leading-relaxed">
            Cung cấp các dịch vụ thí nghiệm và kiểm định chất lượng xây dựng
            chính xác, trung thực, nhanh chóng. Góp phần nâng cao chất lượng các
            công trình xây dựng, bảo đảm an toàn cho cộng đồng.
          </p>
        </div>
      </div>
    </section>

    <!-- Core Values -->
    <section class="py-20 border-t border-border">
      <div class="text-center mb-16">
        <h2
          class="text-3xl md:text-4xl font-heading font-extrabold text-text-primary"
        >
          Giá Trị Cốt Lõi
        </h2>
        <div class="w-16 h-1 bg-accent mx-auto mt-6 rounded-full"></div>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {
          values.map((val) => (
            <div class="bg-white p-8 rounded-xl border border-border shadow-card hover:shadow-card-hover transition-all duration-300 text-center cursor-pointer group">
              <div class="w-14 h-14 bg-accent/10 text-accent rounded-xl flex items-center justify-center mx-auto mb-6 group-hover:bg-accent group-hover:text-white transition-colors duration-300">
                <Fragment set:html={val.icon} />
              </div>
              <h4 class="text-lg font-heading font-bold text-text-primary mb-3">
                {val.title}
              </h4>
              <p class="text-text-secondary text-sm leading-relaxed">
                {val.desc}
              </p>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
