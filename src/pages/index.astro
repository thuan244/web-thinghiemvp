---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ServiceCard from "../components/ServiceCard.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Công ty TNHH Thí nghiệm và Kiểm định xây dựng VP | LAS-XD 53.003 | thinghiemvp.com"
  description="Phòng thí nghiệm LAS-XD 53.003 chuyên thí nghiệm vật liệu xây dựng, kiểm định chất lượng công trình. Được Bộ Xây Dựng công nhận với 128 chỉ tiêu thí nghiệm."
>
  <!-- ==================== HERO ==================== -->
  <section
    class="relative w-full min-h-[600px] md:min-h-[700px] flex items-center justify-center overflow-hidden bg-primary"
  >
    <!-- Background gradient -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-primary via-primary-dark to-bg-dark"
    >
    </div>
    <!-- Decorative circles -->
    <div
      class="absolute top-20 right-20 w-96 h-96 bg-accent/10 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-10 left-10 w-72 h-72 bg-gold/10 rounded-full blur-3xl"
    >
    </div>
    <!-- Grid pattern overlay -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"
    >
    </div>

    <div
      class="relative z-10 max-w-7xl mx-auto px-4 md:px-10 lg:px-20 text-center text-white py-20"
    >
      <div class="max-w-4xl mx-auto space-y-8">
        <!-- Badge -->
        <div
          class="inline-flex items-center gap-2 px-5 py-2 bg-white/10 backdrop-blur-sm rounded-full border border-white/20"
        >
          <div class="w-2 h-2 bg-gold rounded-full animate-pulse"></div>
          <span class="text-xs font-heading font-bold tracking-widest uppercase"
            >Uy tín - Chất lượng - Hiệu quả</span
          >
        </div>

        <!-- Title -->
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-heading font-extrabold leading-tight tracking-tight"
        >
          CÔNG TY TNHH XÂY DỰNG VÀ<br class="hidden md:block" />
          <span class="text-gold-light">THÍ NGHIỆM KIỂM ĐỊNH VP</span>
        </h1>

        <!-- Subtitle -->
        <p
          class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed"
        >
          Phòng Thí Nghiệm Vật Liệu Xây Dựng & Kiểm Định Công Trình<br />
          <span class="font-bold text-white">LAS-XD 53.003</span>
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
          <a
            href={`${base}phong-thi-nghiem/`}
            class="inline-flex items-center justify-center gap-2 bg-white text-primary px-8 py-4 rounded-xl font-heading font-bold hover:bg-bg-light transition-all duration-200 shadow-hero cursor-pointer"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path></svg
            >
            Xem Hồ Sơ Năng Lực
          </a>
          <a
            href={`${base}lien-he/`}
            class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white/40 text-white px-8 py-4 rounded-xl font-heading font-bold hover:bg-white/10 transition-all duration-200 cursor-pointer"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path></svg
            >
            Liên Hệ Ngay
          </a>
        </div>
      </div>

      <!-- Stats Row -->
      <div
        class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl mx-auto"
      >
        <div class="text-center">
          <p
            class="text-3xl md:text-4xl font-heading font-extrabold text-gold-light"
          >
            2+
          </p>
          <p
            class="text-xs text-white/60 font-semibold uppercase tracking-wider mt-1"
          >
            Năm Kinh Nghiệm
          </p>
        </div>

        <div class="text-center">
          <p
            class="text-3xl md:text-4xl font-heading font-extrabold text-gold-light"
          >
            128
          </p>
          <p
            class="text-xs text-white/60 font-semibold uppercase tracking-wider mt-1"
          >
            Chỉ Tiêu Thí Nghiệm
          </p>
        </div>
        <div class="text-center">
          <p
            class="text-3xl md:text-4xl font-heading font-extrabold text-gold-light"
          >
            100+
          </p>
          <p
            class="text-xs text-white/60 font-semibold uppercase tracking-wider mt-1"
          >
            Thiết Bị Hiện Đại
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== ABOUT ==================== -->
  <section class="py-20 px-4 md:px-10 lg:px-20 bg-white">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <!-- Image side -->
      <div class="relative">
        <div
          class="aspect-[4/3] rounded-2xl overflow-hidden shadow-hero bg-bg-light"
        >
          <div
            class="w-full h-full bg-gradient-to-br from-primary/20 to-accent/20 flex items-center justify-center"
          >
            <img
              src={`${base}images/logo-400.png`}
              alt="VP Construction Lab"
              class="w-48 h-48 object-contain opacity-80"
              width="192"
              height="192"
            />
          </div>
        </div>
        <!-- Experience badge -->
        <div
          class="absolute -bottom-6 -right-4 md:-right-6 bg-primary p-6 md:p-8 rounded-2xl shadow-hero"
        >
          <p class="text-white text-4xl font-heading font-extrabold">2+</p>
          <p
            class="text-white/70 text-xs font-semibold uppercase tracking-widest"
          >
            Năm Kinh Nghiệm
          </p>
        </div>
      </div>

      <!-- Text side -->
      <div class="space-y-6">
        <div class="flex items-center gap-2">
          <div class="w-10 h-[2px] bg-accent"></div>
          <span
            class="text-accent font-heading font-bold uppercase tracking-widest text-sm"
            >Về Chúng Tôi</span
          >
        </div>
        <h2
          class="text-3xl md:text-4xl font-heading font-extrabold text-text-primary leading-tight"
        >
          Đối Tác Tin Cậy Cho Mọi Công Trình
        </h2>
        <p class="text-text-secondary leading-relaxed">
          CÔNG TY TNHH XÂY DỰNG VÀ THÍ NGHIỆM KIỂM ĐỊNH VP tự hào là đơn vị hàng
          đầu tại Thái Bình trong lĩnh vực thí nghiệm vật liệu xây dựng và kiểm
          định chất lượng công trình. Với mã hiệu <span
            class="font-bold text-primary">LAS-XD 53.003</span
          >, chúng tôi cam kết mang đến những số liệu chính xác, trung thực,
          phục vụ tốt nhất cho công tác giám sát và quản lý chất lượng xây dựng.
        </p>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            [
              "Thiết bị hiện đại, chuẩn hóa",
              "Đội ngũ kỹ sư chuyên môn cao",
              "Quy trình chuyên nghiệp ISO",
              "Thời gian trả kết quả nhanh",
            ].map((item) => (
              <li class="flex items-center gap-3">
                <svg
                  class="w-5 h-5 text-accent shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                <span class="text-sm font-medium text-text-primary">
                  {item}
                </span>
              </li>
            ))
          }
        </ul>
        <div class="pt-2">
          <a
            href={`${base}gioi-thieu/`}
            class="inline-flex items-center gap-2 bg-accent/10 text-accent px-6 py-3 rounded-lg font-heading font-bold hover:bg-accent hover:text-white transition-all duration-200 cursor-pointer"
          >
            Khám phá chi tiết
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SERVICES ==================== -->
  <section class="py-20 px-4 md:px-10 lg:px-20 bg-bg-light">
    <div class="max-w-7xl mx-auto">
      <SectionHeading
        label="Dịch Vụ Của Chúng Tôi"
        title="Giải Pháp Kiểm Định Toàn Diện"
        description="Cung cấp đầy đủ các dịch vụ thí nghiệm, kiểm định và tư vấn chất lượng xây dựng theo tiêu chuẩn TCVN"
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <ServiceCard
          icon='<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>'
          title="Thí Nghiệm Vật Liệu"
          description="Thử nghiệm các loại vật liệu: Bê tông, cốt thép, xi măng, gạch, cát, đá, nhựa đường và các loại phụ gia xây dựng."
          href={`${base}dich-vu/`}
        />
        <ServiceCard
          icon='<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>'
          title="Kiểm Định Công Trình"
          description="Đánh giá an toàn chịu lực, kiểm định chất lượng công trình cũ và mới, tư vấn giải pháp gia cố sửa chữa hiệu quả."
          href={`${base}dich-vu/`}
        />
        <ServiceCard
          icon='<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
          title="Khảo Sát Địa Chất"
          description="Khoan khảo sát địa chất công trình, thí nghiệm xuyên tĩnh, xuyên tiêu chuẩn (SPT), tư vấn giải pháp móng tối ưu."
          href={`${base}dich-vu/`}
        />
      </div>
    </div>
  </section>

  <!-- ==================== WHY CHOOSE US ==================== -->
  <section class="py-20 px-4 md:px-10 lg:px-20 bg-primary">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-3 gap-12">
      <div class="space-y-6">
        <h2
          class="text-3xl md:text-4xl font-heading font-extrabold text-white leading-tight"
        >
          Tại Sao Chọn LAS-XD 53.003?
        </h2>
        <p class="text-white/60 leading-relaxed">
          Chúng tôi không chỉ cung cấp dịch vụ, chúng tôi cung cấp sự an tâm cho
          mọi công trình.
        </p>
        <a
          href={`${base}lien-he/`}
          class="inline-flex items-center gap-2 bg-white text-primary px-6 py-3 rounded-lg font-heading font-bold hover:bg-bg-light transition-colors duration-200 cursor-pointer"
        >
          Liên hệ chuyên gia
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </a>
      </div>

      <div class="lg:col-span-2 grid md:grid-cols-2 gap-8">
        {
          [
            {
              icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>',
              title: "Chính Xác Tuyệt Đối",
              desc: "Quy trình thí nghiệm nghiêm ngặt theo tiêu chuẩn TCVN và Quốc tế, đảm bảo sai số thấp nhất.",
            },
            {
              icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
              title: "Tiến Độ Nhanh Chóng",
              desc: "Cam kết trả kết quả đúng hạn, hỗ trợ kịp thời cho quá trình nghiệm thu của chủ đầu tư.",
            },
            {
              icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>',
              title: "Đội Ngũ Chuyên Gia",
              desc: "Các kỹ sư, thí nghiệm viên giàu kinh nghiệm, nắm vững các quy chuẩn kỹ thuật hiện hành.",
            },
            {
              icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
              title: "Chi Phí Cạnh Tranh",
              desc: "Giá thành hợp lý, tối ưu chi phí cho đối tác mà vẫn đảm bảo chất lượng dịch vụ tốt nhất.",
            },
          ].map((item) => (
            <div class="flex gap-4">
              <div class="text-white/40 shrink-0">
                <Fragment set:html={item.icon} />
              </div>
              <div>
                <h4 class="text-xl font-heading font-bold text-white mb-2">
                  {item.title}
                </h4>
                <p class="text-sm text-white/60 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="py-20 px-4 md:px-10 lg:px-20 bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2
        class="text-3xl md:text-4xl font-heading font-extrabold text-text-primary mb-6"
      >
        Bạn cần giải pháp cho công trình?
      </h2>
      <p
        class="text-lg text-text-secondary mb-10 leading-relaxed max-w-2xl mx-auto"
      >
        Đội ngũ chuyên gia của chúng tôi luôn sẵn sàng hỗ trợ với các giải pháp
        tối ưu và chi phí hợp lý nhất.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:+84392686659"
          class="inline-flex items-center justify-center gap-3 bg-primary text-white px-10 py-4 rounded-xl font-heading font-bold text-lg hover:bg-primary-light transition-colors duration-200 cursor-pointer shadow-lg shadow-primary/20"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path></svg
          >
          Hotline: 0392.686.659
        </a>
        <a
          href={`${base}lien-he/`}
          class="inline-flex items-center justify-center gap-3 border-2 border-primary text-primary px-10 py-4 rounded-xl font-heading font-bold text-lg hover:bg-primary hover:text-white transition-all duration-200 cursor-pointer"
        >
          Gửi Yêu Cầu Báo Giá
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
