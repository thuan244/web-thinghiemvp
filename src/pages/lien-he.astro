---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const base = import.meta.env.BASE_URL;

const contactInfo = [
  {
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
    label: "Địa chỉ",
    value: "Thôn Kim Sơn 1, xã Hưng Hà, tỉnh Hưng Yên",
    href: undefined,
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>',
    label: "Điện thoại",
    value: "(+84) 392.686.659",
    href: "tel:+84392686659",
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>',
    label: "Email",
    value: "thinghiemvp@gmail.com",
    href: "mailto:thinghiemvp@gmail.com",
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
    label: "Giờ làm việc",
    value: "07:30 - 17:30 (Thứ 2 - Thứ 7)",
    href: undefined,
  },
];

const services = [
  "Thí nghiệm vật liệu",
  "Kiểm định công trình",
  "Khảo sát địa chất",
  "Thử tải công trình",
  "Tư vấn kỹ thuật",
  "Khác",
];
---

<BaseLayout
  title="Liên Hệ | Công ty Thí nghiệm và Kiểm định xây dựng VP"
  description="Liên hệ Công ty TNHH Thí nghiệm và Kiểm định xây dựng VP — Thôn Kim Sơn 1, xã Hưng Hà, tỉnh Hưng Yên. ĐT: 0392.686.659."
>
  <PageHero
    title="Liên Hệ Với Chúng Tôi"
    description="Đội ngũ chuyên gia luôn sẵn sàng hỗ trợ bạn với các giải pháp kiểm định và thí nghiệm tối ưu."
    breadcrumb="Liên Hệ"
  />

  <div class="max-w-7xl mx-auto px-4 md:px-10 lg:px-20 py-20">
    <div class="grid lg:grid-cols-3 gap-12">
      <!-- Contact Info Side -->
      <div class="space-y-8">
        <div>
          <h2
            class="text-2xl font-heading font-extrabold text-text-primary mb-4"
          >
            Thông Tin Liên Hệ
          </h2>
          <p class="text-text-secondary leading-relaxed">
            Hãy liên hệ để được tư vấn miễn phí và nhận báo giá nhanh nhất.
          </p>
        </div>

        <div class="space-y-6">
          {
            contactInfo.map((info) => (
              <div class="flex gap-4">
                <div class="w-12 h-12 bg-accent/10 text-accent rounded-xl flex items-center justify-center shrink-0">
                  <Fragment set:html={info.icon} />
                </div>
                <div>
                  <p class="text-xs font-heading font-bold text-text-muted uppercase tracking-wider">
                    {info.label}
                  </p>
                  {info.href ? (
                    <a
                      href={info.href}
                      class="text-text-primary font-medium hover:text-accent transition-colors cursor-pointer"
                    >
                      {info.value}
                    </a>
                  ) : (
                    <p class="text-text-primary font-medium">{info.value}</p>
                  )}
                </div>
              </div>
            ))
          }
        </div>

        <!-- Map placeholder -->
        <div
          class="aspect-[4/3] bg-bg-light rounded-xl border border-border overflow-hidden"
        >
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2118.2601090744242!2d106.20975111301223!3d20.58484787236091!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135e90b150fb3f1%3A0x9ea32ec93c331824!2zS2ltIFRydW5nLCBIxrBuZyBIw6AsIFRow6FpIELDrG5oLCBWaeG7h3QgTmFt!5e1!3m2!1svi!2s!4v1773850657943!5m2!1svi!2s"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="VP Construction Location"></iframe>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-2">
        <div
          class="bg-white p-8 md:p-10 rounded-2xl border border-border shadow-card"
        >
          <h3
            class="text-2xl font-heading font-extrabold text-text-primary mb-2"
          >
            Gửi Yêu Cầu Báo Giá
          </h3>
          <p class="text-text-secondary mb-8">
            Điền thông tin bên dưới, chúng tôi sẽ phản hồi trong vòng 24 giờ.
          </p>

          <form class="space-y-6" action="#" method="POST">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label
                  for="name"
                  class="block text-sm font-heading font-semibold text-text-primary mb-2"
                  >Họ và Tên <span class="text-red-500">*</span></label
                >
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 border border-border rounded-xl text-sm focus:ring-2 focus:ring-accent/20 focus:border-accent transition-colors"
                  placeholder="Nguyễn Văn A"
                />
              </div>
              <div>
                <label
                  for="phone"
                  class="block text-sm font-heading font-semibold text-text-primary mb-2"
                  >Số điện thoại <span class="text-red-500">*</span></label
                >
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full px-4 py-3 border border-border rounded-xl text-sm focus:ring-2 focus:ring-accent/20 focus:border-accent transition-colors"
                  placeholder="0392 686 659"
                />
              </div>
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-heading font-semibold text-text-primary mb-2"
                >Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-4 py-3 border border-border rounded-xl text-sm focus:ring-2 focus:ring-accent/20 focus:border-accent transition-colors"
                placeholder="email@example.com"
              />
            </div>

            <div>
              <label
                for="service"
                class="block text-sm font-heading font-semibold text-text-primary mb-2"
                >Dịch vụ quan tâm</label
              >
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 border border-border rounded-xl text-sm focus:ring-2 focus:ring-accent/20 focus:border-accent transition-colors bg-white cursor-pointer"
              >
                <option value="">-- Chọn dịch vụ --</option>
                {services.map((s) => <option value={s}>{s}</option>)}
              </select>
            </div>

            <div>
              <label
                for="project"
                class="block text-sm font-heading font-semibold text-text-primary mb-2"
                >Tên công trình / Dự án</label
              >
              <input
                type="text"
                id="project"
                name="project"
                class="w-full px-4 py-3 border border-border rounded-xl text-sm focus:ring-2 focus:ring-accent/20 focus:border-accent transition-colors"
                placeholder="VD: Nhà ở dân dụng 5 tầng tại Thái Bình"
              />
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-heading font-semibold text-text-primary mb-2"
                >Nội dung yêu cầu <span class="text-red-500">*</span></label
              >
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 border border-border rounded-xl text-sm focus:ring-2 focus:ring-accent/20 focus:border-accent transition-colors resize-y"
                placeholder="Mô tả chi tiết yêu cầu của bạn..."></textarea>
            </div>

            <button
              type="submit"
              class="w-full md:w-auto inline-flex items-center justify-center gap-2 bg-primary text-white px-10 py-4 rounded-xl font-heading font-bold text-lg hover:bg-primary-light transition-colors duration-200 cursor-pointer shadow-lg shadow-primary/20"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg
              >
              Gửi Yêu Cầu
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
