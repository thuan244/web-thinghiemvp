---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const base = import.meta.env.BASE_URL;

const testingCategories = [
  { id: 'ximang', label: 'Xi măng & Bê tông', active: true },
  { id: 'cotlieu', label: 'Cốt liệu (Cát, Đá)' },
  { id: 'dat', label: 'Đất & Địa kỹ thuật' },
  { id: 'kimloai', label: 'Kim loại & Mối hàn' },
  { id: 'nhua', label: 'Nhựa đường (Asphalt)' },
  { id: 'vlht', label: 'Vật liệu hoàn thiện' },
];

const testingCards = [
  { icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>', title: 'Thí nghiệm Xi măng', items: ['Độ mịn, thời gian đông kết', 'Cường độ nén và uốn (TCVN 6016)', 'Độ ổn định thể tích'] },
  { icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>', title: 'Thí nghiệm Bê tông', items: ['Cường độ nén mẫu đúc', 'Thử độ sụt bê tông tươi', 'Thí nghiệm không phá hủy (Súng bật nẩy)'] },
  { icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>', title: 'Phân tích thành phần', items: ['Xác định chỉ số hóa học và vật lý', 'Phân tích thành phần cấp phối', 'Kiểm tra phụ gia xây dựng'] },
  { icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>', title: 'Thí nghiệm hiện trường', items: ['Kiểm tra trực tiếp tại công trình', 'Đo đạc và quan trắc tại chỗ', 'Bàn giao kết quả nhanh chóng'] },
];

const inspectionCards = [
  { title: 'Kiểm định Kết cấu', desc: 'Đánh giá hiện trạng an toàn chịu lực của công trình dân dụng và công nghiệp sau thời gian dài sử dụng hoặc khi có dấu hiệu xuống cấp.', items: ['Kiểm định nâng tầng, chuyển đổi công năng', 'Quan trắc lún, nghiêng, nứt công trình'] },
  { title: 'Thử tải Công trình', desc: 'Xác định khả năng chịu lực thực tế của kết cấu sàn, dầm, cầu đường thông qua phương pháp chất tải tĩnh hoặc động.', items: ['Thử tải sàn nhà xưởng, kho bãi', 'Kiểm định cầu, hầm giao thông'] },
  { title: 'Kiểm định Móng', desc: 'Đánh giá chất lượng cọc khoan nhồi, cọc đóng và nền đất để đảm bảo tính ổn định của hệ thống móng.', items: ['Thí nghiệm PDA, PIT, siêu âm cọc', 'Nén tĩnh cọc tải trọng lớn'] },
];
---

<BaseLayout title="Dịch Vụ Thí Nghiệm & Kiểm Định | Công ty VP - LAS-XD 53.003" description="Dịch vụ thí nghiệm vật liệu xây dựng, kiểm định chất lượng công trình, khảo sát địa chất theo tiêu chuẩn LAS-XD 53.003.">

  <PageHero
    title="Dịch vụ Kiểm định & Thí nghiệm Xây dựng"
    description="Đảm bảo tính bền vững và an toàn cho mọi công trình thông qua quy trình kiểm soát chất lượng chuẩn quốc tế."
    breadcrumb="Dịch Vụ"
  />

  <div class="max-w-7xl mx-auto px-4 md:px-10 lg:px-20 py-20">
    <!-- Section 1: Testing -->
    <section class="mb-24">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
        <div class="max-w-2xl">
          <div class="flex items-center gap-2 text-accent font-heading font-bold mb-2">
            <span class="w-8 h-[2px] bg-accent"></span>
            <span class="text-sm uppercase tracking-widest">Danh Mục 01</span>
          </div>
          <h3 class="text-3xl md:text-4xl font-heading font-extrabold text-text-primary mb-4">Phân tích & Thí nghiệm Vật liệu</h3>
          <p class="text-text-secondary text-lg">Hệ thống phòng Lab đạt chuẩn LAS-XD, cung cấp các phép thử chính xác cho mọi loại vật liệu đầu vào và thành phẩm.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- Sidebar Tabs -->
        <div class="lg:col-span-3 flex flex-col gap-2">
          {testingCategories.map((cat, i) => (
            <button class:list={[
              'flex items-center justify-between p-4 rounded-xl font-heading font-bold text-sm transition-all duration-200 cursor-pointer text-left',
              i === 0
                ? 'bg-primary text-white shadow-lg shadow-primary/20'
                : 'bg-white text-text-secondary hover:bg-accent/5'
            ]}>
              <span>{cat.label}</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          ))}
        </div>

        <!-- Content Cards -->
        <div class="lg:col-span-9 grid grid-cols-1 md:grid-cols-2 gap-6">
          {testingCards.map(card => (
            <div class="bg-white p-8 rounded-xl border border-border shadow-card hover:shadow-card-hover transition-all duration-200 cursor-pointer">
              <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center text-accent mb-6">
                <Fragment set:html={card.icon} />
              </div>
              <h4 class="text-xl font-heading font-bold mb-4 text-text-primary">{card.title}</h4>
              <ul class="space-y-3 text-text-secondary text-sm">
                {card.items.map(item => (
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 2: Inspection -->
    <section class="pt-16 border-t border-border">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
        <div class="max-w-2xl">
          <div class="flex items-center gap-2 text-accent font-heading font-bold mb-2">
            <span class="w-8 h-[2px] bg-accent"></span>
            <span class="text-sm uppercase tracking-widest">Danh Mục 02</span>
          </div>
          <h3 class="text-3xl md:text-4xl font-heading font-extrabold text-text-primary mb-4">Kiểm định Chất lượng & Thử tải</h3>
          <p class="text-text-secondary text-lg">Đánh giá an toàn chịu lực, giải quyết tranh chấp kỹ thuật và tư vấn giải pháp gia cố công trình chuyên nghiệp.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {inspectionCards.map(card => (
          <div class="group bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-hover transition-all duration-300 border border-border cursor-pointer">
            <!-- Color header -->
            <div class="h-4 bg-gradient-to-r from-primary to-accent"></div>
            <div class="p-8">
              <h4 class="text-2xl font-heading font-extrabold text-text-primary mb-4">{card.title}</h4>
              <p class="text-text-secondary mb-6 leading-relaxed">{card.desc}</p>
              <ul class="space-y-3 mb-8">
                {card.items.map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span class="text-sm font-medium text-text-primary">{item}</span>
                  </li>
                ))}
              </ul>
              <button class="w-full py-3 bg-bg-light text-text-primary font-heading font-bold rounded-xl hover:bg-primary hover:text-white transition-all duration-200 cursor-pointer">
                Tìm hiểu thêm
              </button>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- CTA -->
  <section class="bg-primary py-20 text-white text-center relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/3"></div>
    <div class="max-w-4xl mx-auto px-4 relative z-10">
      <h3 class="text-3xl md:text-4xl font-heading font-extrabold mb-6">Bạn đang cần giải pháp cho công trình?</h3>
      <p class="text-xl text-white/70 mb-10 leading-relaxed">Đội ngũ chuyên gia luôn sẵn sàng hỗ trợ 24/7 với giải pháp tối ưu và chi phí hợp lý nhất.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+84392686659" class="inline-flex items-center justify-center gap-3 bg-white text-primary px-10 py-4 rounded-xl font-heading font-bold text-lg hover:bg-bg-light transition-colors duration-200 cursor-pointer shadow-hero">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Hotline: 0392.686.659
        </a>
        <a href={`${base}lien-he/`} class="inline-flex items-center justify-center gap-3 border-2 border-white/40 text-white px-10 py-4 rounded-xl font-heading font-bold text-lg hover:bg-white/10 transition-all duration-200 cursor-pointer">
          Gửi Email Yêu Cầu
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
