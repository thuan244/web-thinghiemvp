---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const base = import.meta.env.BASE_URL;

const equipment = [
  { category: 'Thử Nghiệm Cơ Lý', name: 'Universal Testing Machine 1000kN', desc: 'Thiết bị thí nghiệm kéo, nén, uốn các loại thép cường độ cao và vật liệu kim loại xây dựng với độ chính xác tuyệt đối.' },
  { category: 'Thí Nghiệm Bê Tông', name: 'Concrete Compression Machine 2000KN', desc: 'Hệ thống máy nén bê tông tự động, xác định cường độ chịu nén của các mẫu bê tông xi măng, vữa xây dựng.' },
  { category: 'Kiểm Định Phi Phá Hoại', name: 'Ultrasonic Pulse Velocity Device', desc: 'Thiết bị đo vận tốc xung siêu âm nhằm đánh giá độ đồng nhất và khuyết tật bên trong cấu kiện bê tông.' },
  { category: 'Địa Kỹ Thuật', name: 'Thiết bị xuyên tiêu chuẩn SPT', desc: 'Thiết bị khoan khảo sát địa chất, thí nghiệm xuyên tiêu chuẩn SPT phục vụ thiết kế nền móng công trình.' },
  { category: 'Thí Nghiệm Đất', name: 'Máy nén cố kết đất', desc: 'Xác định tính chất cơ lý của đất nền, hệ số cố kết, tính nén lún phục vụ tính toán lún nền công trình.' },
  { category: 'Hiện Trường', name: 'Súng bật nẩy Schmidt', desc: 'Kiểm tra cường độ bê tông bằng phương pháp không phá hủy trực tiếp trên kết cấu công trình hiện hữu.' },
];

const team = [
  { name: 'KS. Nguyễn Văn Thành', role: 'Trưởng phòng thí nghiệm', desc: 'Hơn 15 năm kinh nghiệm quản lý LAS-XD và kiểm định chất lượng công trình dân dụng.' },
  { name: 'KS. Lương Thanh Sơn', role: 'Phó phòng thí nghiệm', desc: 'Chuyên gia về thí nghiệm địa kỹ thuật và quan trắc lún công trình cao tầng.' },
  { name: 'KS. Trần Minh Hiếu', role: 'Kỹ thuật viên trưởng', desc: 'Phụ trách công tác thí nghiệm hiện trường và bàn giao kết quả nhanh chóng, chính xác.' },
  { name: 'KS. Lê Hoàng Long', role: 'Chuyên viên thí nghiệm', desc: 'Kiểm soát quy trình thí nghiệm vật liệu xây dựng mới và tư vấn giải pháp kỹ thuật.' },
];
---

<BaseLayout title="Năng Lực Thiết Bị & Nhân Sự | Công ty VP - LAS-XD 53.003" description="Hệ thống thiết bị thí nghiệm hiện đại, đội ngũ kỹ sư chuyên nghiệp với 128 chỉ tiêu thí nghiệm được Bộ Xây Dựng công nhận.">

  <PageHero
    title="Năng Lực Thiết Bị & Nhân Sự"
    description="Công ty TNHH Thí nghiệm và Kiểm định xây dựng VP tự hào sở hữu hệ thống phòng thí nghiệm LAS-XD đạt chuẩn cùng đội ngũ chuyên gia đầu ngành."
    breadcrumb="Năng Lực"
  />

  <div class="max-w-7xl mx-auto px-4 md:px-10 lg:px-20 py-20">
    <!-- Stats Bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-20">
      {[
        { value: '2+', label: 'Năm kinh nghiệm' },
        { value: '128', label: 'Chỉ tiêu thí nghiệm' },
        { value: '10+', label: 'Kỹ sư & chuyên gia' },
      ].map(stat => (
        <div class="bg-white p-6 rounded-xl text-center shadow-card border border-border">
          <p class="text-3xl font-heading font-extrabold text-primary">{stat.value}</p>
          <p class="text-sm text-text-secondary font-medium mt-1">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Equipment Section -->
    <section class="mb-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl font-heading font-extrabold text-text-primary mb-2">Hệ Thống Thiết Bị Chuyên Dụng</h2>
          <p class="text-accent font-heading font-semibold flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            Hơn 100 thiết bị chuyên dụng hiện đại
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {equipment.map(item => (
          <div class="group bg-white rounded-xl overflow-hidden shadow-card border border-border hover:shadow-card-hover transition-all duration-300 cursor-pointer">
            <!-- Placeholder image area -->
            <div class="h-48 bg-gradient-to-br from-primary/10 to-accent/10 flex items-center justify-center">
              <svg class="w-16 h-16 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div class="p-6">
              <div class="text-xs font-heading font-bold text-accent mb-2 uppercase tracking-widest">{item.category}</div>
              <h3 class="text-lg font-heading font-bold text-text-primary mb-2">{item.name}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Team Section -->
    <section>
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-heading font-extrabold text-text-primary mb-4">Đội Ngũ Chuyên Gia</h2>
        <p class="text-text-secondary max-w-2xl mx-auto">Tập hợp những kỹ sư, kỹ thuật viên có bề dày kinh nghiệm, am hiểu sâu sắc về các tiêu chuẩn kỹ thuật Việt Nam và Quốc tế.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {team.map(member => (
          <div class="bg-white p-6 rounded-xl border border-border shadow-card hover:shadow-card-hover transition-all duration-300 flex flex-col items-center text-center cursor-pointer">
            <!-- Avatar placeholder -->
            <div class="w-28 h-28 rounded-full overflow-hidden mb-4 border-4 border-accent/10 bg-gradient-to-br from-primary/20 to-accent/20 flex items-center justify-center">
              <svg class="w-12 h-12 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <h4 class="text-lg font-heading font-bold text-text-primary">{member.name}</h4>
            <p class="text-accent font-heading font-semibold text-sm mb-3">{member.role}</p>
            <p class="text-text-muted text-xs leading-relaxed">{member.desc}</p>
            <div class="flex gap-3 mt-4">
              <a href="#" class="text-text-muted hover:text-accent transition-colors cursor-pointer" aria-label="Email">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </a>
              <a href="#" class="text-text-muted hover:text-accent transition-colors cursor-pointer" aria-label="Phone">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>

</BaseLayout>
