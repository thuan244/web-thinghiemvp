---
interface Props {
  label?: string;
  title: string;
  description?: string;
  centered?: boolean;
  light?: boolean;
}

const { label, title, description, centered = true, light = false } = Astro.props;
---

<div class:list={['mb-12 md:mb-16', centered && 'text-center', 'max-w-3xl', centered && 'mx-auto']}>
  {label && (
    <div class:list={['flex items-center gap-2 mb-3', centered && 'justify-center']}>
      <div class:list={['w-8 h-[2px]', light ? 'bg-white/60' : 'bg-accent']}></div>
      <span class:list={[
        'text-sm font-heading font-bold uppercase tracking-widest',
        light ? 'text-white/80' : 'text-accent'
      ]}>{label}</span>
    </div>
  )}
  <h2 class:list={[
    'text-3xl md:text-4xl font-heading font-extrabold leading-tight',
    light ? 'text-white' : 'text-text-primary'
  ]}>{title}</h2>
  {description && (
    <p class:list={[
      'mt-4 text-lg leading-relaxed',
      light ? 'text-white/70' : 'text-text-secondary'
    ]}>{description}</p>
  )}
  {centered && !light && (
    <div class="w-16 h-1 bg-accent mx-auto mt-6 rounded-full"></div>
  )}
</div>
