---
interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumb?: string | BreadcrumbItem[];
}

const { title, description, breadcrumb } = Astro.props;
const base = import.meta.env.BASE_URL;
const isArray = Array.isArray(breadcrumb);
---

<section class="relative bg-primary py-16 md:py-24 overflow-hidden">
  <!-- Decorative -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-white rounded-full translate-y-1/2 -translate-x-1/4"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 md:px-10 lg:px-20">
    {breadcrumb && (
      <nav class="mb-6 text-sm text-white/60" aria-label="Breadcrumb">
        <a href={`${base}`} class="hover:text-white transition-colors cursor-pointer">Trang Chủ</a>
        {isArray ? (
          (breadcrumb as BreadcrumbItem[]).map((item, i, arr) => (
            <>
              <span class="mx-2">/</span>
              {i < arr.length - 1 ? (
                <a href={item.href} class="hover:text-white transition-colors cursor-pointer">{item.label}</a>
              ) : (
                <span class="text-white font-semibold">{item.label}</span>
              )}
            </>
          ))
        ) : (
          <>
            <span class="mx-2">/</span>
            <span class="text-white font-semibold">{breadcrumb}</span>
          </>
        )}
      </nav>
    )}
    <h1 class="text-4xl md:text-5xl font-heading font-extrabold text-white leading-tight max-w-3xl">{title}</h1>
    {description && (
      <p class="mt-6 text-lg md:text-xl text-white/80 max-w-2xl leading-relaxed">{description}</p>
    )}
  </div>
</section>
