---
const base = import.meta.env.BASE_URL;
---

<footer class="bg-bg-dark text-white">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 md:px-10 lg:px-20 pt-16 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Company Info -->
      <div class="space-y-6">
        <a href={`${base}`} class="flex items-center gap-3 cursor-pointer">
          <img
            src={`${base}images/logo-200.png`}
            alt="VP Logo"
            class="h-10 w-10 object-contain"
            width="40"
            height="40"
          />
          <div>
            <h2 class="font-heading font-extrabold text-lg">LAS-XD 53.003</h2>
            <p
              class="text-[10px] font-semibold uppercase tracking-widest text-white/60"
            >
              VP Construction
            </p>
          </div>
        </a>
        <p class="text-sm text-slate-400 leading-relaxed">
          Đơn vị uy tín hàng đầu trong lĩnh vực thí nghiệm vật liệu và kiểm định
          xây dựng tại Thái Bình và các tỉnh phía Bắc.
        </p>
        <div class="flex gap-3">
          <a
            href="#"
            class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center hover:bg-primary-light transition-colors duration-200 cursor-pointer"
            aria-label="Facebook"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path></svg
            >
          </a>
          <a
            href="mailto:thinghiemvp@gmail.com"
            class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center hover:bg-primary-light transition-colors duration-200 cursor-pointer"
            aria-label="Email"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg
            >
          </a>
          <a
            href="tel:+84392686659"
            class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center hover:bg-primary-light transition-colors duration-200 cursor-pointer"
            aria-label="Phone"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path></svg
            >
          </a>
        </div>
      </div>

      <!-- Contact Info -->
      <div class="space-y-6">
        <h4
          class="font-heading font-bold text-lg border-b border-white/10 pb-3"
        >
          Liên Hệ
        </h4>
        <ul class="space-y-4 text-sm text-slate-400">
          <li class="flex gap-3">
            <svg
              class="w-4 h-4 mt-0.5 text-accent shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
            >
            <span>Thôn Kim Sơn 1, xã Hưng Hà, Tỉnh Hưng Yên</span>
          </li>
          <li class="flex gap-3">
            <svg
              class="w-4 h-4 mt-0.5 text-accent shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path></svg
            >
            <a
              href="tel:+84392686659"
              class="hover:text-white transition-colors cursor-pointer"
              >(+84) 392.686.659</a
            >
          </li>
          <li class="flex gap-3">
            <svg
              class="w-4 h-4 mt-0.5 text-accent shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg
            >
            <a
              href="mailto:thinghiemvp@gmail.com"
              class="hover:text-white transition-colors cursor-pointer"
              >thinghiemvp@gmail.com</a
            >
          </li>
          <li class="flex gap-3">
            <svg
              class="w-4 h-4 mt-0.5 text-accent shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path></svg
            >
            <span>MST: 1001277165</span>
          </li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div class="space-y-6">
        <h4
          class="font-heading font-bold text-lg border-b border-white/10 pb-3"
        >
          Liên Kết Nhanh
        </h4>
        <ul class="space-y-3 text-sm text-slate-400">
          <li>
            <a
              href={`${base}gioi-thieu/`}
              class="hover:text-white transition-colors cursor-pointer"
              >Giới thiệu công ty</a
            >
          </li>
          <li>
            <a
              href={`${base}dich-vu/`}
              class="hover:text-white transition-colors cursor-pointer"
              >Dịch vụ thí nghiệm</a
            >
          </li>
          <li>
            <a
              href={`${base}nang-luc/`}
              class="hover:text-white transition-colors cursor-pointer"
              >Năng lực thiết bị</a
            >
          </li>
          <li>
            <a
              href={`${base}phong-thi-nghiem/`}
              class="hover:text-white transition-colors cursor-pointer"
              >Phòng thí nghiệm</a
            >
          </li>
          <li>
            <a
              href={`${base}lien-he/`}
              class="hover:text-white transition-colors cursor-pointer"
              >Liên hệ báo giá</a
            >
          </li>
        </ul>
      </div>

      <!-- Certifications -->
      <div class="space-y-6">
        <h4
          class="font-heading font-bold text-lg border-b border-white/10 pb-3"
        >
          Chứng Nhận
        </h4>
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div
              class="w-20 h-12 bg-white/10 rounded-lg flex items-center justify-center border border-white/20 px-2"
            >
              <span class="text-[8px] font-bold text-center leading-tight"
                >Sở xây dựng Thái Bình<br />LAS-XD 53.003</span
              >
            </div>
            <div class="text-xs text-slate-400">
              <p class="font-semibold text-white">Phòng LAS-XD</p>
              <p>Sở Xây Dựng Thái Bình cấp</p>
            </div>
          </div>
          <div class="bg-white/5 p-4 rounded-lg border border-white/10">
            <p class="text-xs text-slate-400 leading-relaxed">
              Cam kết tuân thủ nghiêm ngặt các tiêu chuẩn TCVN và quy chuẩn kỹ
              thuật hiện hành trong mọi hoạt động thí nghiệm và kiểm định.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-white/10">
    <div
      class="max-w-7xl mx-auto px-4 md:px-10 lg:px-20 py-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-500"
    >
      <p>
        &copy; {new Date().getFullYear()} CÔNG TY TNHH XÂY DỰNG VÀ THÍ NGHIỆM KIỂM
        ĐỊNH VP. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition-colors cursor-pointer"
          >Chính sách bảo mật</a
        >
        <a href="#" class="hover:text-white transition-colors cursor-pointer"
          >Điều khoản sử dụng</a
        >
      </div>
    </div>
  </div>
</footer>
